//
//  APIKeys.swift.example
//  joribee
//
//  이 파일을 복사하여 APIKeys.swift로 이름을 바꾼 뒤 실제 키를 입력하세요.
//  APIKeys.swift는 .gitignore에 의해 커밋되지 않습니다.
//  발급처: https://developers.naver.com → 애플리케이션 등록 → 검색 API
//

// API 키를 저장하는 구조체 (git에 커밋되지 않음)
struct APIKeys {
    // 네이버 개발자 센터에서 발급받은 Client ID
    static let naverClientId     = "YOUR_CLIENT_ID"
    // 네이버 개발자 센터에서 발급받은 Client Secret
    static let naverClientSecret = "YOUR_CLIENT_SECRET"
}
